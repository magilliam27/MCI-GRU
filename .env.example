# MCI-GRU Environment Variables
# Copy this file to .env and fill in the values you need.

# Required when features.include_credit_spread=true or features.include_global_regime=true
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# MLflow tracking URI (optional, defaults to local ./mlruns)
# MLFLOW_TRACKING_URI=http://localhost:5000
